# After deploying contracts to testnet, fill in the package IDs:
#
# 1. Deploy suicryptolib:
#    cd move && sui client publish --gas-budget 200000000
#    Copy the package ID from the output
#
# 2. Update sealed_auction/move/Move.toml to reference published suicryptolib
#    Then deploy sealed_auction:
#    cd examples/sealed_auction/move && sui client publish --gas-budget 200000000
#    Copy the package ID from the output
#
# 3. Paste both IDs below and restart the dev server

VITE_LIB_PACKAGE_ID=0x_PASTE_SUICRYPTOLIB_PACKAGE_ID_HERE
VITE_AUCTION_PACKAGE_ID=0x_PASTE_SEALED_AUCTION_PACKAGE_ID_HERE
